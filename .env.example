TELEGRAM_BOT_TOKEN=
ENCRYPTION_KEY=
DB_PATH=./data/app.db
EXPORTS_DIR=./exports
GARMIN_WORKDIR_ROOT=./data/users
WEBAPP_BASE_URL=https://your-domain.example/garmin
WEBAPP_TOKEN_TTL_SECONDS=900
ADMIN_USER_IDS=123456789
# Command template for syncing Garmin data via GarminDB.
# Available placeholders: {output_dir}, {username}, {config_dir}
# Garmin credentials are written into {config_dir}/GarminConnectConfig.json.
GARMIN_DB_SYNC_CMD=garmindb_cli.py --config {config_dir} -d -i --analyze -A

# AI for daily health analysis (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MODEL_FALLBACKS=claude-sonnet-4-20250514

# Voice transcription (OpenAI Whisper) — optional, enables voice messages
OPENAI_API_KEY=

# Wake detection scheduler
POLL_START_HOUR=5
POLL_END_HOUR=12
POLL_INTERVAL_MINUTES=15
USER_TIMEZONE=Europe/Moscow
PAYMENT_PROVIDER_TOKEN=
